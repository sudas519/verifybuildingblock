# IBM Verify Tenant
IBM_VERIFY_TENANT_URL=https://emeabuildlab.verify.ibm.com

# API Client credentials — create an API client in IBM Verify under
# Security > API Access > API Clients (grant_type: client_credentials)
IBM_VERIFY_CLIENT_ID=your-api-client-id
IBM_VERIFY_CLIENT_SECRET=your-api-client-secret

# IBM Verify Company/Tenant ID (visible in Admin > Company Settings)
COMPANY_ID=your-company-id
